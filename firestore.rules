rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: trades
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - symbol: string (required) - Trading pair
    //   - type: string (required) - BUY/SELL
    //   - profit: number (required) - Realized PnL
    //   - fees: number (required) - Trading fees
    //   - timestamp: timestamp (required) - When trade closed
    //
    // Collection: user_stats
    // Document ID: userId
    // Fields:
    //   - userId: string (required)
    //   - totalProfit: number (required)
    //   - totalFeesOwed: number (required)
    //   - totalFeesPaid: number (required)
    //   - amountOwed: number (required)
    //   - isLocked: bool (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aryanad1234567890@gmail.com" && request.auth.token.email_verified == true));
    }

    // Trades Collection
    match /trades/{tradeId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && 
                      request.resource.data.keys().hasAll(['userId', 'symbol', 'type', 'profit', 'fees', 'timestamp']);
      allow update, delete: if false; // Trades are immutable records
    }

    // User Stats Collection
    match /user_stats/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['userId', 'totalProfit', 'totalFeesOwed', 'totalFeesPaid', 'amountOwed', 'isLocked']);
      allow update: if isOwner(userId) || isAdmin();
    }
  }
}
