rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // VALIDATION BLUEPRINTS
    // -------------------------------------------------------------------------
    
    function isValidUserStats(data) {
      return data.keys().hasAll(['balance', 'lastUpdated']) &&
             data.balance is number &&
             data.lastUpdated is number;
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['id', 'symbol', 'type', 'lotSize', 'entryPrice', 'openTime', 'status', 'accountType']) &&
             data.id is string &&
             data.symbol is string &&
             data.type in ['BUY', 'SELL'] &&
             data.lotSize is number &&
             data.entryPrice is number &&
             data.openTime is number &&
             data.status in ['OPEN', 'CLOSED'] &&
             data.accountType in ['PAPER', 'REAL'];
    }

    function isValidSupportTicket(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'subject', 'message', 'status', 'createdAt', 'recipient']) &&
             data.userId is string &&
             data.userEmail is string &&
             data.subject is string &&
             data.message is string &&
             data.status == 'OPEN' &&
             data.recipient == 'nebulamarketai@gmail.com';
    }

    // -------------------------------------------------------------------------
    // ACCESS RULES
    // -------------------------------------------------------------------------
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles & Stats
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users should not list other users
      
      allow create: if isOwner(userId) && isValidUserStats(incoming());
      
      allow update: if isOwner(userId) && isValidUserStats(incoming()) && (
        // Action: Balance Sync
        incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'equity', 'totalProfit', 'totalTrades', 'winRate', 'lastUpdated'])
      );
    }

    // User Trades Subcollection
    match /users/{userId}/trades/{tradeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      
      allow create: if isOwner(userId) && isValidTrade(incoming()) && isValidId(tradeId);
      
      allow update: if isOwner(userId) && isValidTrade(incoming()) && (
        // Action: Close Trade
        (existing().status == 'OPEN' && incoming().status == 'CLOSED' && 
         incoming().diff(existing()).affectedKeys().hasAll(['status', 'closePrice', 'closeTime', 'pnl']) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'closePrice', 'closeTime', 'pnl'])) ||
        // Action: Update Risk (SL/TP)
        (existing().status == 'OPEN' && incoming().diff(existing()).affectedKeys().hasOnly(['stopLoss', 'takeProfit']))
      );
      
      allow delete: if false; // Immutability of history
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if isSignedIn() && isValidSupportTicket(incoming());
      allow get: if isSignedIn() && (incoming().userId == request.auth.uid);
      allow list: if false;
    }
  }
}
