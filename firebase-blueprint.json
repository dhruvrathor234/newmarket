{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user balance, equity, and bot configuration",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "strategy": { "type": "string" },
        "isRunning": { "type": "boolean" },
        "accountType": { "type": "string", "enum": ["PAPER", "REAL"] },
        "tradingMode": { "type": "string", "enum": ["SPOT", "FUTURES"] },
        "statusMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "balance", "equity"]
    },
    "Trade": {
      "title": "Trading Position",
      "description": "Stores details of an open or closed trade",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED", "PENDING"] },
        "entryPrice": { "type": "number" },
        "closePrice": { "type": "number" },
        "pnl": { "type": "number" },
        "lotSize": { "type": "number" },
        "openTime": { "type": "number" },
        "closeTime": { "type": "number" },
        "accountType": { "type": "string" }
      },
      "required": ["userId", "symbol", "type", "status", "entryPrice"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user financial state and bot settings"
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Individual trades linked to a userId"
    }
  }
}
