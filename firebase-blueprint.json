{
  "entities": {
    "UserStats": {
      "title": "User Stats",
      "description": "Aggregated stats and balance for a user",
      "type": "object",
      "properties": {
        "balance": { "type": "number", "description": "Current wallet balance" },
        "equity": { "type": "number", "description": "Current equity including open PnL" },
        "totalProfit": { "type": "number", "description": "Lifetime realized profit" },
        "totalTrades": { "type": "number", "description": "Total count of closed trades" },
        "winRate": { "type": "number", "description": "Percentage of winning trades" },
        "lastUpdated": { "type": "number", "description": "Last sync timestamp" },
        "accountType": { "type": "string", "enum": ["PAPER", "REAL"] }
      },
      "required": ["balance", "lastUpdated"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A single trading position record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "lotSize": { "type": "number" },
        "entryPrice": { "type": "number" },
        "closePrice": { "type": "number" },
        "openTime": { "type": "number" },
        "closeTime": { "type": "number" },
        "stopLoss": { "type": "number" },
        "takeProfit": { "type": "number" },
        "pnl": { "type": "number" },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"] },
        "accountType": { "type": "string", "enum": ["PAPER", "REAL"] }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User message for the support team",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"] },
        "createdAt": { "type": "object", "description": "Firestore Server Timestamp" },
        "recipient": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserStats",
      "description": "Public user stats and active balance"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Trade history and open positions for the user"
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "End-to-end encrypted support transmissions"
    }
  }
}
